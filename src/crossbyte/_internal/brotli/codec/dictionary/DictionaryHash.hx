package crossbyte._internal.brotli.codec.dictionary;

import haxe.crypto.Base64;

class DictionaryHash {
	public static final contents:Array<UInt> = __decode([
		"",
		"",
		"",
		"",
		"",
		"",
		"",
		"",
		"",
		"",
		""
	].join(""));

	private static function __decode(encoded:String):Array<UInt> {
		var bytes = Base64.decode(encoded);
		var out:Array<UInt> = [];
		out.resize(bytes.length);
		for (i in 0...bytes.length) {
			out[i] = bytes.get(i);
		}
		return out;
	}
}
