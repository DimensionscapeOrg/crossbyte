<xml>
	<files id="crossbyte-blake3-common">
		<depend files="hxcpp-depends"/>
		<compilerflag value="-I${this_dir}/vendor/blake3"/>
		<!-- Keep the native backend deterministic across hxcpp releases by
		     using the portable BLAKE3 path in CI and default native builds. -->
		<compilerflag value="-DBLAKE3_NO_SSE2"/>
		<compilerflag value="-DBLAKE3_NO_SSE41"/>
		<compilerflag value="-DBLAKE3_NO_AVX2"/>
		<compilerflag value="-DBLAKE3_NO_AVX512"/>
		<file name="${this_dir}/NativeBlake3.cpp"/>
		<file name="${this_dir}/vendor/blake3/blake3.c"/>
		<file name="${this_dir}/vendor/blake3/blake3_portable.c"/>
		<file name="${this_dir}/vendor/blake3/blake3_dispatch.c"/>
	</files>

	<target id="haxe">
		<files id="crossbyte-blake3-common"/>
	</target>
</xml>
